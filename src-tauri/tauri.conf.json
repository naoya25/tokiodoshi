{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tokiodoshi",
  "version": "0.1.0",
  "identifier": "com.naoya.tokiodoshi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "tokiodoshi",
        "width": 720,
        "height": 540,
        "minWidth": 480,
        "minHeight": 360,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["assets/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
